{
  "files": {
    "includes": ["**", "!**/.direnv", "!**/dist", "!**/docs", "!**/node_modules"]
  },

  "formatter": {
    "indentStyle": "space",
    "lineWidth": 120
  },

  "linter": {
    "rules": {
      "suspicious": {
        "noShadowRestrictedNames": "off",
        "noExplicitAny": "off"
      },
      "complexity": {
        "useArrowFunction": "off",
        "noArguments": "off"
      }
    }
  }
}
